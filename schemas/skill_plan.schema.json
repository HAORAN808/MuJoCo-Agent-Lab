{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.robot-lab-agent/schemas/skill_plan.schema.json",
  "title": "SkillPlan",
  "type": "object",
  "required": [
    "plan_id",
    "robot_id",
    "skills"
  ],
  "properties": {
    "plan_id": {
      "type": "string"
    },
    "robot_id": {
      "type": "string"
    },
    "end_effector": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "skill_name",
          "params"
        ],
        "properties": {
          "skill_name": {
            "type": "string"
          },
          "params": {
            "type": "object"
          },
          "preconditions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected_observations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "safety_limits": {
      "type": "object",
      "default": {}
    }
  },
  "additionalProperties": true
}
